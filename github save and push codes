cat << 'EOF' > commands.txt
# === Packwiz Modpack Update Workflow ===

# 1. Refresh the pack index after changing files manually
packwiz refresh

# 2. Stage all changes for Git
git add .

# 3. Commit the changes with a message
git commit -m "Update modpack files"

# 4. Push changes to GitHub (uses your saved token automatically)
git push
EOF
